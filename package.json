{
  "name": "music-cards-player",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "//clean-pc": "powershell -Command \"Remove-Item -r node_modules, dist, *.tsbuildinfo\"",
    "clean": "node -e \"fs.rmSync('node_modules',{recursive:true,force:true});fs.rmSync('dist',{recursive:true,force:true});fs.readdirSync('.').filter(f=>f.endsWith('.tsbuildinfo')).forEach(f=>fs.rmSync(f,{force:true}))\""
  },
  "dependencies": {
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "html5-qrcode": "^2.3.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/spotify-web-playback-sdk": "^0.1.19",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
